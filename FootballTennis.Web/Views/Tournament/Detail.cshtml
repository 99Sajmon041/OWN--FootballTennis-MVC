@model TournamentDetailViewModel

@{
    ViewData["Title"] = "Správa a detail turnaje";
}

@if (User.IsInRole(nameof(AdminRole.Admin)))
{
    <div class="text-center mb-5">
        <h1 class="display-4">Detail a správa turnaje</h1>
    </div>
}
else
{
    <div class="text-center mb-5">
        <h1 class="display-4">Detail turnaje</h1>
    </div>
}


<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-8 col-xl-9">

        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Název</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Místo</dt>
                    <dd class="col-sm-8">@Model.Address</dd>

                    <dt class="col-sm-4">Datum</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("dd.MM.yyyy")</dd>

                    <dt class="col-sm-4">Počet hráčů v týmu</dt>
                    <dd class="col-sm-8">@Model.TeamPlayersCount</dd>

                    <dt class="col-sm-4">Počet týmů</dt>
                    <dd class="col-sm-8">
                        @(Model.TeamsCount == 0 ? "Zatím nejsou týmy" : Model.TeamsCount.ToString())
                    </dd>

                    <dt class="col-sm-4">Počet kol</dt>
                    <dd class="col-sm-8">
                        @(Model.Status == Status.Scheduled ? "Turnaj není zahájen" : Model.RoundsCount.ToString())
                    </dd>

                    <dt class="col-sm-4">Počet zápasů</dt>
                    <dd class="col-sm-8">
                        @(Model.Status == Status.Scheduled ? "Turnaj není zahájen" : Model.MatchesCount.ToString())
                    </dd>

                    <dt class="col-sm-4">Počet zápasů na tým</dt>
                    <dd class="col-sm-8">
                        @(
                            Model.Status == Status.Scheduled ? "Turnaj není zahájen" : $"{Model.TeamsCount - 1}"
                        )
                    </dd>

                    <dt class="col-sm-4">Odehrané zápasy</dt>
                    <dd class="col-sm-8">
                        @(Model.Status == Status.Scheduled ? "Turnaj není zahájen" : Model.Matches.Where(x => x.MatchStatus == MatchStatus.Played).Count().ToString() + " / " + Model.MatchesCount.ToString())
                    </dd>

                </dl>

            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">
                Týmy
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Název týmu</th>
                            <th>Hráči</th>
                            <th>Počet výher</th>
                            <th>
                                Akce
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Model.TeamsCount > 0)
                        {
                            @foreach(var team in Model.Teams.OrderByDescending(x => x.WinsCount).ThenBy(x => x.Name))
                            {
                                <tr>
                                    <td>@team.Id</td>
                                    <td>@team.Name</td>
                                    <td>
                                        @CollectionHelper.GetTeamPlayersAsString(team.TeamPlayers)
                                    </td>
                                    <td>
                                        @if (Model.Status == Status.Scheduled)
                                        {
                                            <span>-</span>
                                        }
                                        else
                                        {
                                            <span>@team.WinsCount</span>
                                        }
                                    </td>
                                    <td>
                                        @if (Model.Status == Status.Scheduled)
                                        {
                                            @if (User.IsInRole(nameof(AdminRole.Admin)))
                                            {
                                                <a class="btn btn-sm btn-warning my-2"
                                                    asp-controller="Team" 
                                                    asp-action="Update" 
                                                    asp-route-tournamentId="@Model.Id"
                                                    asp-route-id="@team.Id">
                                                    Upravit
                                                </a>

                                                <form asp-controller="Team"
                                                      asp-action="Delete"
                                                      asp-route-tournamentId="@Model.Id"
                                                      asp-route-id="@team.Id"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('Opravdu chcete tým: @team.Name smazat?');">

                                                    @Html.AntiForgeryToken()

                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        Smazat
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-bold mx-1">Nemáte oprávnění</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="fw-bold mx-1">Akce již nejsou povoleny</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4">
                                    <div class="alert alert-secondary mb-0">
                                        Zatím nejsou žádné týmy.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Status == Status.Scheduled && User.IsInRole(nameof(AdminRole.Admin)))
        {
            <div class="d-flex justify-content-end mb-3">
                <a class="btn btn-primary" asp-controller="Team" asp-action="Create" asp-route-tournamentId="@Model.Id" asp-route-teamPlayersCount="@Model.TeamPlayersCount">
                    Přidat tým
                </a>
            </div>
        }

        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">
                Zápasy
            </div>
            <div class="card-body">
                <table class="table @(Model.MatchesCount > 0 ? "table-striped" : "table-borderless") mb-0">
                    <thead>
                        <tr>
                            <th>Jméno týmu 1</th>
                            <th>Jméno týmu 2</th>
                            <th>Odehráno</th>
                            <th>Skóre</th>
                            <th>Pořadí zápasu</th>
                            <th>Akce</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.MatchesCount > 0)
                        {
                            @foreach (var match in Model.Matches.OrderBy(x => x.Order))
                            {
                                <tr>
                                    <td>@match.TeamOneName</td>
                                    <td>@match.TeamTwoName</td>
                                    <td>@EnumHelper.GetCzechMatchStatusName(match.MatchStatus)</td>
                                    <td class="text-center">
                                        @if (match.MatchStatus == MatchStatus.Played)
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">
                                                @match.ScoreText
                                            </span>
                                        }
                                        else if (match.MatchStatus == MatchStatus.Playing)
                                        {
                                            <span class="badge bg-info px-3 py-2 rounded-pill">
                                                @match.ScoreText
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@match.ScoreText</span>
                                        }
                                    </td>
                                    <td class="text-center">@match.Order</td>
                                    <td>
                                        @if (User.IsInRole(nameof(AdminRole.Admin)))
                                        {
                                            @if (Model.Status == Status.InProgress)
                                            {
                                                <a class="btn btn-sm btn-primary" asp-controller="Match" asp-action="Update" asp-route-tournamentId="@Model.Id" asp-route-id="@match.Id">
                                                    Upravit
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Úprava je dostupná jen během turnaje</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">Nemáte oprávnění</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <div class="alert alert-secondary mb-0">
                                        Zatím nejsou žádné zápasy.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Status == Status.Scheduled && User.IsInRole(nameof(AdminRole.Admin)))
        {
            <p class="text-muted small text-center mb-3 mt-1">
                Turnaj ještě není zahájen.
                @if (Model.TeamsCount < 3)
                {
                    <span>Nejdřív vytvořte týmy (3 a více).</span>
                }
                Jakmile budou týmy připravené, můžete vygenerovat zápasy, turnaj se tak automaticky zahájí.
            </p>
        }

        @if (Model.Status == Status.Scheduled && User.IsInRole(nameof(AdminRole.Admin)) && Model.TeamsCount >= 3)
        {
            <div class="d-flex justify-content-end mb-3">
                <form method="post" asp-controller="Tournament" asp-action="CreateMatches" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()

                    <button class="btn btn-success" type="submit">
                        Vygenerovat zápasy (zahájit turnaj)
                    </button>
                </form>
            </div>
        }

        <div class="d-flex justify-content-between mt-2">
            <a class="btn btn-outline-primary" asp-action="Index" asp-controller="Tournament">
                Zpět
            </a>

            @if (Model.Status == Status.Finished)
            {
                <a class="btn btn-success" asp-action="Statistics" asp-controller="Tournament" asp-route-id="@Model.Id">
                    Tabulka / statistiky
                </a>
            }
            else if (User.IsInRole(nameof(AdminRole.Admin)) && Model.Status == Status.InProgress)
            {
                <form method="post" asp-action="Evaluate" asp-controller="Tournament" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-success"
                            disabled="@(!Model.Matches.All(x => x.MatchStatus == MatchStatus.Played))">
                        Vyhodnotit turnaj
                    </button>
                </form>
            }
        </div>
    </div>
</div>