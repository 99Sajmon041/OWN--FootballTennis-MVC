@model TournamentsTeamStatisticsViewModel

@{
    ViewData["Title"] = "Statistika týmu";
}

<div class="text-center mb-4">
    <h1 class="display-5 mb-3">Statistika týmu: @Model.TeamName</h1>
    <h3 class="fw-bold text-secondary mb-4">@Model.TournamentName</h3>
</div>

<div class="row justify-content-center mb-4">
    <div class="col-12 col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-body py-3">
                <div class="row text-center g-3">
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase">Umístění</div>
                        <div class="fs-4 fw-bold">@Model.Position.</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase">Výhry</div>
                        <div class="fs-4 fw-bold text-success">@Model.WonMatches</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase">Prohry</div>
                        <div class="fs-4 fw-bold text-danger">@Model.LostMatches</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center mb-4">
    <div class="col-12 col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-body fw-semibold text-center">
                Sestava týmu
            </div>
            <div class="card-body text-center">
                @if (Model.Players is not null && Model.Players.Count > 0)
                {
                    <div class="text-muted small mb-3">
                        Počet hráčů: <strong>@Model.Players.Count</strong>
                    </div>

                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        @foreach (var player in Model.Players)
                        {
                            <span class="badge rounded-pill bg-info-subtle text-info-emphasis px-3 py-2 fs-6">
                                @player.FullName
                            </span>
                        }
                    </div>
                }
                else
                {
                    <span class="text-muted">Tým nemá přiřazené žádné hráče.</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center mb-3">
    <div class="col-12 col-lg-10">
        <form method="get" asp-controller="Tournament" asp-action="TeamStatistics" class="d-flex align-items-end gap-3 flex-wrap">
            <input type="hidden" name="tournamentId" value="@Model.TournamentId" />

            <div style="min-width: 240px;">
                <label class="form-label fw-semibold" asp-for="TeamId">Vyberte tým</label>
                <select class="form-select" asp-for="TeamId" asp-items="Model.Teams" onchange="this.form.submit()"></select>
            </div>
        </form>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-body fw-semibold">
                Statistiky zápasů
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Soupeř</th>
                            <th>Výsledek</th>
                            <th>1. set</th>
                            <th>2. set</th>
                            <th>3. set</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var wonSetsAtMatches = 0;
                            var lostSetsAtmatches = 0;

                            var wonPointsIn1Sets = 0;
                            var lostPointsIn1Sets = 0;

                            var wonPointsIn2Sets = 0;
                            var lostPointsIn2Sets = 0;

                            var wonPointsIn3Sets = 0;
                            var lostPointsIn3Sets = 0;
                        }

                        @foreach (var match in Model.Matches)
                        {
                            var wonSets = match.Sets.Count(x => x.TeamScore > x.OpponentScore);
                            var lostSets = match.Sets.Count(x => x.OpponentScore > x.TeamScore);
                            var matchResultClass = wonSets > lostSets
                            ? "bg-success-subtle text-success-emphasis"
                            : "bg-danger-subtle text-danger-emphasis";

                            wonSetsAtMatches += wonSets;
                            lostSetsAtmatches += lostSets;

                            if (match.Sets.Count > 0)
                            {
                                wonPointsIn1Sets += match.Sets[0].TeamScore;
                                lostPointsIn1Sets += match.Sets[0].OpponentScore;
                            }

                            if (match.Sets.Count > 1)
                            {
                                wonPointsIn2Sets += match.Sets[1].TeamScore;
                                lostPointsIn2Sets += match.Sets[1].OpponentScore;
                            }

                            if (match.Sets.Count > 2)
                            {
                                wonPointsIn3Sets += match.Sets[2].TeamScore;
                                lostPointsIn3Sets += match.Sets[2].OpponentScore;
                            }

                            <tr>
                                <td class="fw-semibold">@match.TeamName</td>

                                <td>
                                    <span class="badge rounded-pill px-3 py-2 @matchResultClass" style="border: 1px solid black;">
                                        @wonSets : @lostSets
                                    </span>
                                </td>

                                @for (int i = 0; i < 3; i++)
                                {
                                    @if (i < match.Sets.Count)
                                    {
                                        var set = match.Sets[i];
                                        var wasNotPlayed = set.TeamScore == 0 && set.OpponentScore == 0;
                                        var setClass = wasNotPlayed
                                        ? "bg-secondary-subtle text-secondary-emphasis"
                                        : set.TeamScore > set.OpponentScore
                                        ? "bg-success-subtle text-success-emphasis"
                                        : "bg-danger-subtle text-danger-emphasis";

                                        <td>
                                            @if (wasNotPlayed)
                                            {
                                                <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis px-3 py-2">
                                                    Nehrál se
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill px-3 py-2 @setClass">
                                                    @set.TeamScore : @set.OpponentScore
                                                </span>
                                            }
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary-emphasis px-3 py-2">
                                                Nehráno
                                            </span>
                                        </td>
                                    }
                                }
                            </tr>
                        }

                        <tr class="table-light fw-bold border-top">
                            <td class="text-uppercase text-muted small align-middle">Souhrn</td>

                            <td>
                                <div class="d-flex flex-column">
                                    <span class="small text-muted fw-semibold">Sety celkem</span>
                                    <span>@wonSetsAtMatches : @lostSetsAtmatches</span>
                                </div>
                            </td>

                            <td>
                                <div class="d-flex flex-column">
                                    <span class="small text-muted fw-semibold">1. set</span>
                                    <span>@wonPointsIn1Sets : @lostPointsIn1Sets</span>
                                </div>
                            </td>

                            <td>
                                <div class="d-flex flex-column">
                                    <span class="small text-muted fw-semibold">2. set</span>
                                    <span>@wonPointsIn2Sets : @lostPointsIn2Sets</span>
                                </div>
                            </td>

                            <td>
                                <div class="d-flex flex-column">
                                    <span class="small text-muted fw-semibold">3. set</span>
                                    <span>@wonPointsIn3Sets : @lostPointsIn3Sets</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-12 col-lg-10 d-flex justify-content-between">
        <a class="btn btn-outline-primary" asp-controller="Tournament" asp-action="Statistics" asp-route-id="@Model.TournamentId">
            Zpět
        </a>

        <a class="btn btn-primary" asp-controller="Tournament" asp-action="Detail" asp-route-id="@Model.TournamentId">
            Detail turnaje
        </a>
    </div>
</div>